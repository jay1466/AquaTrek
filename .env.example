##############################################################
# AquaTrack — Environment Variables
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values below (especially secrets)
#   3. NEVER commit .env to version control
##############################################################


# ── Spring Profile ─────────────────────────────────────────────
# Options: dev | prod
SPRING_PROFILES_ACTIVE=dev


# ── Database ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquatrack_db
DB_USERNAME=aquatrack_user
DB_PASSWORD=aquatrack_pass

# Connection pool sizes
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2


# ── JWT ────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random 256-bit secret for production.
# Use: openssl rand -base64 64
JWT_SECRET=ChangeThisToA256BitSecretKeyInProduction!AquaTrack2024Secure

# Token expiry in milliseconds
JWT_ACCESS_EXPIRY_MS=900000      # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000  # 7 days


# ── Mail / SMTP ────────────────────────────────────────────────
# For local dev, use MailHog (started by docker-compose): host=localhost, port=1025
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@aquatrack.com
MAIL_FROM_NAME=AquaTrack


# ── Application URLs ───────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
SWAGGER_SERVER_URL=http://localhost:8080


# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_CAPACITY=100
RATE_LIMIT_REFILL=100
RATE_LIMIT_PERIOD=60


# ── Server ─────────────────────────────────────────────────────
SERVER_PORT=8080


# ── Frontend (Vite) ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_PORT=5173


# ── Swagger ────────────────────────────────────────────────────
# Set to false in production
SWAGGER_ENABLED=true


# ── Logging ────────────────────────────────────────────────────
LOG_PATH=./logs
